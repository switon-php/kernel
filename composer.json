{
    "name": "switon/kernel",
    "description": "Application bootstrap for environment, config, provider lifecycle, and fatal error handling for Switon Framework",
    "type": "library",
    "keywords": [
        "switon",
        "kernel",
        "bootstrap",
        "providers"
    ],
    "homepage": "https://github.com/switon-php/kernel",
    "license": "MIT",
    "authors": [
        {
            "name": "switon",
            "email": "admin@switon.dev"
        }
    ],
    "support": {
        "source": "https://github.com/switon-php/kernel",
        "issues": "https://github.com/switon-php/kernel/issues",
        "docs": "https://docs.switon.dev/latest/kernel"
    },
    "require": {
        "php": ">=8.3",
        "psr/log": "^2.0",
        "switon/command": "^1.0",
        "switon/composer-extra": "^1.0",
        "switon/core": "^1.0",
        "switon/di": "^1.0",
        "switon/event": "^1.0",
        "switon/yaml": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "switon/testing": "^1.0",
        "phpstan/extension-installer": "^1.4"
    },
    "config": {
        "allow-plugins": {
            "switon/composer-extra": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Switon\\Kernel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Switon\\Kernel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "@php vendor/bin/phpstan analyse",
        "test:unit": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=unit --display-deprecations --display-phpunit-notices",
        "test": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=all --display-deprecations --display-phpunit-notices"
    },
    "extra": {
        "switon": {
            "commands": [
                "Switon\\Kernel\\Command\\VersionCommand"
            ],
            "providers": []
        },
        "branch-alias": {
            "dev-dev": "1.0.x-dev"
        }
    }
}
